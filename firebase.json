{
  "hosting": {
    "site": "presently-6151f",
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "public/firebase/firestore.rules"
  },
  "database": {
    "rules": "public/firebase/database.rules.json"
  }
}
