// Firestore Security Rules
// Copy this to Firestore Database > Rules in Firebase Console

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check super-admin status
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email in [
        'samuelrobingera@gmail.com',
        'hello@buildplaylearn.xyz'
      ];
    }

    // Users can read and write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // All authenticated users can read rooms
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      // Only admin users can write to rooms (you can modify this later)
      allow write: if request.auth != null &&
        (request.auth.token.admin == true ||
         resource == null ||
         resource.data.occupiedBy == request.auth.uid);
    }

    // Organizations - Multi-strategy access control
    match /organizations/{orgId} {
      // Read: authenticated users in the org OR super-admins
      allow read: if request.auth != null &&
        (request.auth.token.email == resource.data.ownerEmail ||
         request.auth.token.email in resource.data.adminEmails ||
         request.auth.uid == resource.data.ownerId ||
         request.auth.uid in resource.data.adminIds ||
         isSuperAdmin());

      // Write: only super-admins
      allow create, update, delete: if isSuperAdmin();
    }
    
    // Bookings - Users can see bookings for rooms they have access to
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Refine this later based on orgId
    }

    // Sessions - users can only access their own sessions or display them
    match /sessions/{sessionId} {
      // Allow unauthenticated direct document reads for Display View
      allow get: if true;
      // Block collection queries for unauthenticated users (prevents data scraping)
      allow list: if request.auth != null;
      // Only session owner can write
      allow write: if request.auth != null &&
        (resource == null || resource.data.userId == request.auth.uid);
    }
    
    // Analytics (read-only for authenticated users)
    match /analytics/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only server can write analytics
    }
  }
}